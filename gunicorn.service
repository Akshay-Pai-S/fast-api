#setup this in /etc/systemd/system/social-api.service file
[Unit]
Description=FastAPI Social API

[Service]
user=akshay
group=akshay
WorkingDirectory=/home/akshay/app/src
Environment="PATH=/home/akshay/app/venv_fastapi/bin"
EnvironmentFile=/home/akshay/.env
ExecStart=/home/akshay/app/venv_fastapi/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker app.main:app --bind 0.0.0.0:8000

[Install]
WantedBy=multi-user.target